# =============================================================================
# TANGER CODE — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key-at-least-50-chars
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,api.tangercode.test

# --- Database (PostgreSQL) ---
POSTGRES_DB=tangercode
POSTGRES_USER=tangercode
POSTGRES_PASSWORD=tangercode_dev_pwd
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://tangercode:tangercode_dev_pwd@postgres:5432/tangercode

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Anthropic (Claude API) ---
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_SERVICE_ACCOUNT_PATH=/app/secrets/ga4-service-account.json

# --- reCAPTCHA v3 ---
RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# --- SMTP (a2hosting / dev: console) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.tangercode.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=contact@tangercode.com

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
NEXT_PUBLIC_WHATSAPP_NUMBER=+212600000000

# --- Encryption (for API keys in DB) ---
FERNET_ENCRYPTION_KEY=

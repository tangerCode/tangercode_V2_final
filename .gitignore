# =============================================================================
# TANGER CODE — Global .gitignore
# =============================================================================

# --- Environment ---
.env
.env.*
!.env.example
!.env.local.example

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
.pytest_cache/
.coverage
htmlcov/
.tox/
.ruff_cache/

# --- Node ---
node_modules/
.next/
out/
.turbo/

# --- Docker ---
*.log
docker-compose.override.yml

# --- Secrets ---
secrets/
*.pem
*.key
*.crt
ga4-service-account.json

# --- Media uploads ---
media/
